    "ali-oss": "^6.0.0",
    "better-auth": "^1.3.7",
    "bullmq": "^5.58.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.10.1",
    "ioredis": "^5.8.1",
    "postgres": "^3.4.7",
    "smol-toml": "^1.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
