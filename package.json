{
  "name": "hono-enterprise-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/app/http/server.ts",
    "dev:worker": "bun --hot src/app/worker/index.ts",
    "dev:scheduler": "bun --hot src/app/scheduler/index.ts",
    "typecheck": "tsc --noEmit",
